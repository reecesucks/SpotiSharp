<?xml version="1.0" encoding="UTF-8"?>

<Shell
    x:Class="SpotiSharp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SpotiSharp"
    xmlns:views="using:SpotiSharp.Views"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{DynamicResource FlyoutBackground}">

    <!-- blank flyout icon: hides the hamburger, swipe from the left edge still opens the menu -->
    <Shell.FlyoutIcon>
        <FontImageSource Glyph=" " FontFamily="OpenSansRegular" Color="Transparent" />
    </Shell.FlyoutIcon>

    <!-- Vintage iPod title bar sitting above the menu list. -->
    <Shell.FlyoutHeader>
        <Grid HeightRequest="56"
              BackgroundColor="{DynamicResource NavBarBackground}">
            <Label Text="spotify f25"
                   FontAttributes="Bold"
                   FontSize="24"
                   CharacterSpacing="0.5"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
            <!-- Settings gear, top-right. Vector path so it themes with the rest of the bar. -->
            <Grid HorizontalOptions="End"
                  VerticalOptions="Center"
                  WidthRequest="44"
                  HeightRequest="44"
                  Margin="0,0,6,0"
                  BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsGearTapped" />
                </Grid.GestureRecognizers>
                <Path HorizontalOptions="Center"
                      VerticalOptions="Center"
                      HeightRequest="24"
                      WidthRequest="24"
                      Aspect="Uniform"
                      Fill="{DynamicResource NavBarForeground}"
                      Data="F0 M19.14,12.94a7.49,7.49,0,0,0,0-1.88l2-1.58a.5.5,0,0,0,.12-.61l-1.92-3.32a.5.5,0,0,0-.61-.22l-2.39,1a7,7,0,0,0-1.62-.94l-.36-2.54A.5.5,0,0,0,13.87,2H10.13a.5.5,0,0,0-.49.42L9.28,4.96a7,7,0,0,0-1.62.94l-2.39-1a.5.5,0,0,0-.61.22L2.74,8.44a.5.5,0,0,0,.12.61l2,1.58a7.49,7.49,0,0,0,0,1.88l-2,1.58a.5.5,0,0,0-.12.61l1.92,3.32a.5.5,0,0,0,.61.22l2.39-1a7,7,0,0,0,1.62.94l.36,2.54a.5.5,0,0,0,.49.42h3.74a.5.5,0,0,0,.49-.42l.36-2.54a7,7,0,0,0,1.62-.94l2.39,1a.5.5,0,0,0,.61-.22l1.92-3.32a.5.5,0,0,0-.12-.61ZM12,15.6A3.6,3.6,0,1,1,15.6,12,3.6,3.6,0,0,1,12,15.6Z" />
            </Grid>
            <BoxView HeightRequest="1"
                     VerticalOptions="End"
                     Color="{DynamicResource Divider}" />
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Each flyout item is a full-width row: page name on the left, a disclosure arrow on the
         right, and a highlight bar when selected — the classic click-wheel iPod menu look. -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="*,Auto"
                  Padding="20,0"
                  HeightRequest="52">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource FlyoutBackground}" />
                                    <Setter TargetName="RowTitle" Property="Label.TextColor" Value="{DynamicResource TextPrimary}" />
                                    <Setter TargetName="RowChevron" Property="Path.Stroke" Value="{DynamicResource TextSecondary}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource SelectedRowBackground}" />
                                    <Setter TargetName="RowTitle" Property="Label.TextColor" Value="{DynamicResource SelectedRowText}" />
                                    <Setter TargetName="RowChevron" Property="Path.Stroke" Value="{DynamicResource SelectedRowText}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Label x:Name="RowTitle"
                       Grid.Column="0"
                       Text="{Binding Title}"
                       FontSize="18"
                       VerticalOptions="Center"
                       TextColor="{DynamicResource TextPrimary}" />
                <Path x:Name="RowChevron"
                      Grid.Column="1"
                      VerticalOptions="Center"
                      HeightRequest="16"
                      WidthRequest="9"
                      Aspect="Uniform"
                      Stroke="{DynamicResource TextSecondary}"
                      StrokeThickness="2.6"
                      StrokeLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M0,0 L7,6 L0,12" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <ShellContent
        x:Name="HomeContent"
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        x:Name="RadioContent"
        Title="Radio"
        ContentTemplate="{DataTemplate views:RadioPage}"
        Route="RadioPage" />
    <ShellContent
        x:Name="PlaylistCreatorContent"
        Title="Create Playlists"
        ContentTemplate="{DataTemplate views:PlaylistCreatorPage}"
        Route="PlaylistCreatorPage" />
    <ShellContent
        x:Name="ManagePlaylistsContent"
        Title="Manage Playlists"
        ContentTemplate="{DataTemplate local:ManagePlaylistsPage}"
        Route="ManagePlayListsPage" />
    <ShellContent
        x:Name="PlaylistsContent"
        Title="Playlists"
        ContentTemplate="{DataTemplate views:PlaylistsPage}"
        Route="PlaylistsPage" />
    <ShellContent
        x:Name="ArtistsContent"
        Title="Artists"
        ContentTemplate="{DataTemplate views:ArtistsPage}"
        Route="ArtistsPage" />
    <ShellContent
        x:Name="AlbumsContent"
        Title="Albums"
        ContentTemplate="{DataTemplate views:AlbumsPage}"
        Route="AlbumsPage" />
    <ShellContent
        x:Name="PodcastsContent"
        Title="Podcasts"
        ContentTemplate="{DataTemplate views:PodcastsPage}"
        Route="PodcastsPage" />
    <ShellContent
        x:Name="AuthenticationContent"
        Title="Authentication"
        ContentTemplate="{DataTemplate local:AuthenticationPage}"
        Route="AuthenticationPage" />
    <ShellContent
        x:Name="SettingsContent"
        Title="Settings"
        ContentTemplate="{DataTemplate views:SettingsPage}"
        Route="SettingsPage" />
</Shell>