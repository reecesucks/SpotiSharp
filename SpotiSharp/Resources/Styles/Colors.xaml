<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Theme-independent colours only. Everything that changes with the selected theme lives in
         Themes/SpotifyTheme.xaml and Themes/IpodTheme.xaml and must be referenced with
         DynamicResource so it repaints when the theme is swapped at runtime. -->

    <Color x:Key="Yellow100Accent">#F7B548</Color>
    <Color x:Key="Yellow200Accent">#FFD590</Color>
    <Color x:Key="Yellow300Accent">#FFE5B9</Color>
    <Color x:Key="Cyan100Accent">#28C2D1</Color>
    <Color x:Key="Cyan200Accent">#7BDDEF</Color>
    <Color x:Key="Cyan300Accent">#C3F2F4</Color>
    <Color x:Key="Blue100Accent">#3E8EED</Color>
    <Color x:Key="Blue200Accent">#72ACF1</Color>
    <Color x:Key="Blue300Accent">#A7CBF6</Color>

    <Color x:Key="Green100">#24C7A9</Color>
    <Color x:Key="Green200">#41D195</Color>
    <Color x:Key="Green300">#1DB954</Color>
    <Color x:Key="Green400">#3FD150</Color>
    <Color x:Key="Green500">#34C71C</Color>
    <Color x:Key="Red">Red</Color>

</ResourceDictionary>
