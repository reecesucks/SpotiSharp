<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    x:Class="SpotiSharp.Themes.IpodTheme"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <x:String x:Key="BodyFont">ChicagoKare</x:String>

    <!-- Vintage click-wheel iPod: warm off-white paper, brushed silver panels, menu blue. -->
    <Color x:Key="PageBackground">#F4F3ED</Color>
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>
    <Color x:Key="SurfaceAlt">#E3E2DC</Color>
    <Color x:Key="FlyoutBackground">#EDEBE3</Color>
    <Color x:Key="NavBarBackground">#DAD8D0</Color>
    <Color x:Key="NavBarForeground">#2E6DB4</Color>
    <Color x:Key="TextPrimary">#1B1B19</Color>
    <Color x:Key="TextSecondary">#5B5A54</Color>
    <Color x:Key="TextMuted">#8A897F</Color>
    <Color x:Key="Divider">#C7C5BC</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>

    <!-- Selected menu row: dark grey bar, text inverted to the light menu background colour. -->
    <Color x:Key="SelectedRowBackground">#2B2B29</Color>
    <Color x:Key="SelectedRowText">#EDEBE3</Color>

    <Color x:Key="Danger">#A8403A</Color>
    <Color x:Key="OnDanger">#FFFFFF</Color>
    <Color x:Key="Accent">#C8862E</Color>
    <Color x:Key="OnAccent">#FFFFFF</Color>

    <!-- Legacy keys are mapped by the role they play in existing markup, not by luminance:
         Gray900 is a panel/button fill, Gray300/500 are muted foregrounds, Gray100 is text
         sitting on Gray600. Inverting them keeps every existing view readable. -->
    <Color x:Key="Primary">#2E6DB4</Color>
    <Color x:Key="Secondary">#C6C9CE</Color>
    <Color x:Key="Tertiary">#F4F3ED</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#1B1B19</Color>
    <Color x:Key="Gray100">#2A2A28</Color>
    <Color x:Key="Gray200">#B9B8B1</Color>
    <Color x:Key="Gray300">#5E5D57</Color>
    <Color x:Key="Gray400">#949389</Color>
    <Color x:Key="Gray500">#7C7B74</Color>
    <Color x:Key="Gray600">#CFCEC7</Color>
    <Color x:Key="Gray900">#E3E2DC</Color>
    <Color x:Key="Gray950">#DAD8D0</Color>

</ResourceDictionary>
