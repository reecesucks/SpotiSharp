<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    x:Class="SpotiSharp.Themes.SpotifyTheme"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <x:String x:Key="BodyFont">OpenSansRegular</x:String>

    <!-- Semantic palette. Prefer these keys in new markup. -->
    <Color x:Key="PageBackground">#000000</Color>
    <Color x:Key="SurfaceBackground">#121212</Color>
    <Color x:Key="SurfaceAlt">#212121</Color>
    <Color x:Key="FlyoutBackground">#121212</Color>
    <Color x:Key="NavBarBackground">#141414</Color>
    <Color x:Key="NavBarForeground">#1DB954</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B3B3B3</Color>
    <Color x:Key="TextMuted">#6E6E6E</Color>
    <Color x:Key="Divider">#2A2A2A</Color>
    <!-- Foreground drawn on top of a Primary-coloured fill -->
    <Color x:Key="OnPrimary">#000000</Color>

    <!-- Selected menu row: subtle dark highlight with the brand green as the label colour. -->
    <Color x:Key="SelectedRowBackground">#282828</Color>
    <Color x:Key="SelectedRowText">#1DB954</Color>

    <!-- Destructive actions (delete, remove, validation failures) -->
    <Color x:Key="Danger">#B33A3A</Color>
    <Color x:Key="OnDanger">#FFFFFF</Color>
    <!-- Secondary accent: marks podcast content apart from music -->
    <Color x:Key="Accent">#E8A33D</Color>
    <Color x:Key="OnAccent">#1B1B19</Color>

    <!-- Legacy palette keys, kept so existing markup keeps working. -->
    <Color x:Key="Primary">#1DB954</Color>
    <Color x:Key="Secondary">#D9D9D9</Color>
    <Color x:Key="Tertiary">#000000</Color>
    <Color x:Key="White">#C8C8C8</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

</ResourceDictionary>
