<?xml version="1.0" encoding="utf-8"?>

<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SpotiSharp.Views"
             xmlns:controls="clr-namespace:SpotiSharp.Controls"
             Shell.NavBarIsVisible="False"
             x:Class="SpotiSharp.Views.RadioSettingsPage">
    <views:BasePage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="10">
                <controls:PlayerBarButton Grid.Column="0"
                                          WidthRequest="44"
                                          HeightRequest="44"
                                          VerticalOptions="Center"
                                          Margin="0,0,5,0"
                                          Command="{Binding GoBack}">
                    <Path Fill="{StaticResource Gray300}"
                          Aspect="Uniform"
                          WidthRequest="20"
                          HeightRequest="20"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          InputTransparent="True"
                          Data="M15.41,7.41L14,6l-6,6l6,6l1.41-1.41L10.83,12L15.41,7.41z" />
                </controls:PlayerBarButton>
                <Label Grid.Column="1"
                       Text="Radio Settings"
                       FontSize="28"
                       VerticalOptions="Center" />
            </Grid>

            <CarouselView Grid.Row="1"
                          ItemsSource="{Binding Pages}"
                          IndicatorView="PageIndicator"
                          Loop="False">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <VerticalStackLayout Grid.Row="0" Margin="10,0,10,6" Spacing="0">
                                <Label Text="{Binding Title}" FontSize="16" />
                                <Label Text="0 = off · higher weight plays more often" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                            <ActivityIndicator Grid.Row="1"
                                               IsRunning="{Binding IsLoading}"
                                               IsVisible="{Binding IsLoading}"
                                               HeightRequest="32"
                                               VerticalOptions="Start" />
                            <CollectionView Grid.Row="1"
                                            ItemsSource="{Binding Items}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="10,4">
                                            <Image Grid.Column="0"
                                                   Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="44"
                                                   WidthRequest="44" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="16"
                                                   Margin="10,0,10,0"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="2"
                                                   Text="{Binding Weight}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Primary}"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,10,0">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Weight}" Value="0">
                                                        <Setter Property="TextColor" Value="{StaticResource Gray500}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Stepper Grid.Column="3"
                                                     Minimum="0"
                                                     Maximum="3"
                                                     Increment="1"
                                                     Value="{Binding Weight}"
                                                     VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <IndicatorView Grid.Row="2"
                           x:Name="PageIndicator"
                           IndicatorColor="{StaticResource Gray600}"
                           SelectedIndicatorColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           Margin="0,4,0,4" />
        </Grid>
    </views:BasePage.Content>
</views:BasePage>
