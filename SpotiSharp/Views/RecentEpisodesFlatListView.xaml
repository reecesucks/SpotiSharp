<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             x:DataType="viewmodels:RecentEpisodesFlatViewModel"
             x:Class="SpotiSharp.Views.RecentEpisodesFlatListView">
    <Grid>
        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <CollectionView ItemsSource="{Binding Episodes}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RecentEpisode">
                    <Grid ColumnDefinitions="44,*" Padding="8,8">
                        <Image Grid.Column="0"
                               Source="{Binding ShowImageUrl}"
                               Aspect="AspectFill"
                               HeightRequest="44"
                               WidthRequest="44" />
                        <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                            <Label Text="{Binding EpisodeName}"
                                   FontSize="19"
                                   LineBreakMode="TailTruncation" />
                            <Label FontSize="16" TextColor="{DynamicResource TextSecondary}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding ShowName}" />
                                        <Span Text=" · " />
                                        <Span Text="{Binding ReleaseDate, StringFormat='{0:d}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>

        <!-- Opaque cover shown while the list first populates, so the rows inflate under it
             instead of janking the swipe into this page. -->
        <Grid IsVisible="{Binding IsLoading}" BackgroundColor="{DynamicResource PageBackground}">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               HeightRequest="40"
                               WidthRequest="40"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentView>
