<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpotiSharp.Views.RecentEpisodesFlatListView">
    <Grid>
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                            IsVisible="{Binding IsLoading}"
                            HeightRequest="32"
                            VerticalOptions="Start" />
        <CollectionView ItemsSource="{Binding Episodes}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="44,*" Padding="8,8">
                        <Image Grid.Column="0"
                               Source="{Binding ShowImageUrl}"
                               Aspect="AspectFill"
                               HeightRequest="44"
                               WidthRequest="44" />
                        <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                            <Label Text="{Binding EpisodeName}"
                                   FontSize="19"
                                   LineBreakMode="TailTruncation" />
                            <Label FontSize="16" TextColor="Gray">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding ShowName}" />
                                        <Span Text=" · " />
                                        <Span Text="{Binding ReleaseDate, StringFormat='{0:d}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>
