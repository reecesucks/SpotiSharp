<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             x:DataType="viewmodels:AlbumListViewModel"
             x:Class="SpotiSharp.Views.AlbumListView">
    <Grid>
    <ActivityIndicator IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        HeightRequest="32"
                        VerticalOptions="Start" />
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
    <CollectionView x:Name="MainListView"
              ItemsSource="{Binding Albums}"
              SelectionMode="Single"
              SelectedItem="{Binding SelectedAlbum}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Album">
                <Grid Margin="0,2,0,0" ColumnDefinitions="Auto,*" AutomationId="{Binding AlbumId}">
                    <Image Grid.Column="0"
                           Source="{Binding AlbumImageUrl}"
                           Aspect="AspectFill"
                           HeightRequest="60"
                           WidthRequest="60" />
                    <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                        <Label FontSize="18"
                               LineBreakMode="TailTruncation"
                               Text="{Binding AlbumName}" />
                        <Label FontSize="14"
                               TextColor="{DynamicResource TextSecondary}"
                               LineBreakMode="TailTruncation"
                               Text="{Binding ArtistNames}" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    </RefreshView>
    </Grid>
</ContentView>
