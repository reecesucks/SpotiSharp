<?xml version="1.0" encoding="utf-8"?>

<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SpotiSharp.Views"
             x:Class="SpotiSharp.Views.SettingsPage"
                Title="Settings">
    <views:BasePage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="1" Margin="10" RowDefinitions="Auto,Auto" RowSpacing="0">
                <!-- Collaboration host controls, hidden while the feature is disabled.
                     Flip IsVisible to True (and re-enable StorageHandler.IsUsingCollaborationHost) to restore. -->
                <VerticalStackLayout Grid.Row="0" IsVisible="False" Spacing="4">
                    <Label Text="Settings" FontSize="35"/>
                    <Label Text="Use CollaborationHost" />
                    <Switch IsToggled="{Binding IsUsingCollaborationHost}"/>
                    <Label Text="CollaborationHost Address" />
                    <Entry Text="{Binding CollaborationHostAddress}" Placeholder="[IP/Domain]:[Port] example: http://127.0.0.1:5000" />
                    <Label Text="CollaborationSession" />
                    <Entry Text="{Binding CollaborationSession}" />
                    <Button Text="Apply Settings" Command="{Binding ApplySettings}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Spacing="4">
                <Label Text="Theme" />
                <Grid ColumnDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="8"
                      HorizontalOptions="Start">
                    <Label Grid.Column="0"
                           Text="iPod"
                           VerticalOptions="Center"
                           TextColor="{DynamicResource TextSecondary}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Source={x:Reference ThemeSwitch}, Path=IsToggled}"
                                         Value="False">
                                <Setter Property="TextColor" Value="{DynamicResource Primary}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                    <Switch x:Name="ThemeSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Toggled="OnThemeSwitchToggled" />
                    <Label Grid.Column="2"
                           Text="Spotify"
                           VerticalOptions="Center"
                           TextColor="{DynamicResource TextSecondary}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Source={x:Reference ThemeSwitch}, Path=IsToggled}"
                                         Value="True">
                                <Setter Property="TextColor" Value="{DynamicResource Primary}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>

                <Label Text="Playback device" Margin="0,12,0,0" />
                <Picker ItemsSource="{Binding Devices}"
                        SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        HorizontalOptions="Start"
                        MinimumWidthRequest="240" />
                <Button Text="Use current device"
                        Command="{Binding UseCurrentDevice}"
                        HorizontalOptions="Start"
                        Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </views:BasePage.Content>
</views:BasePage>