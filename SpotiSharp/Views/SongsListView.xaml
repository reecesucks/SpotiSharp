<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             x:DataType="viewmodels:SongsListViewModel"
             x:Class="SpotiSharp.SongsListView">
    <Grid>
    <ActivityIndicator IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        HeightRequest="32"
                        VerticalOptions="Start" />
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
    <CollectionView x:Name="MainListView"
        ItemsSource="{Binding Songs}"
        SelectionMode="Single">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Song">
                <Grid ColumnDefinitions="Auto,Auto" AutomationId="{Binding SongId}">
                    <Image Grid.Column="0"
                           x:Name="SongImage"
                           Source="{Binding SongImageURL}"
                           Aspect="AspectFill"
                           HeightRequest="60"
                           WidthRequest="60" />
                    <VerticalStackLayout Grid.Column="1" Spacing="0" Margin="10,0,0,0" VerticalOptions="Center">
                        <Label x:Name="SongName"
                               Text="{Binding SongTitle}" />
                        <Label x:Name="SongArtists"
                               Text="{Binding SongArtists}" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    </RefreshView>
    </Grid>
</ContentView>