<?xml version="1.0" encoding="utf-8"?>

<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SpotiSharp.Views"
             xmlns:controls="clr-namespace:SpotiSharp.Controls"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             x:DataType="viewmodels:DetailAlbumPageViewModel"
             Shell.NavBarIsVisible="False"
             x:Class="SpotiSharp.Views.DetailAlbumPage">
    <views:BasePage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*" Margin="10">
                <controls:PlayerBarButton Grid.Column="0"
                                          WidthRequest="44"
                                          HeightRequest="44"
                                          VerticalOptions="Center"
                                          Margin="0,0,5,0"
                                          Command="{Binding GoBack}">
                    <Path Fill="{DynamicResource Gray300}"
                          Aspect="Uniform"
                          WidthRequest="20"
                          HeightRequest="20"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          InputTransparent="True"
                          Data="M15.41,7.41L14,6l-6,6l6,6l1.41-1.41L10.83,12L15.41,7.41z" />
                </controls:PlayerBarButton>
                <Grid Grid.Column="1" WidthRequest="60" HeightRequest="60">
                    <Image Source="{Binding AlbumImageUrl}"
                           Aspect="AspectFill"
                           HeightRequest="60"
                           WidthRequest="60" />
                    <controls:PlayerBarButton HorizontalOptions="End"
                                              VerticalOptions="End"
                                              WidthRequest="24"
                                              HeightRequest="24"
                                              Command="{Binding ToggleAlbumSaved}">
                        <Border StrokeShape="Ellipse"
                                StrokeThickness="0"
                                BackgroundColor="{DynamicResource Gray600}"
                                WidthRequest="22"
                                HeightRequest="22">
                            <Label Text="+"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="{DynamicResource Gray100}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsAlbumSaved}" Value="True">
                                        <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsAlbumSaved}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>
                    </controls:PlayerBarButton>
                </Grid>
                <Label Grid.Column="2"
                       Text="{Binding AlbumName}"
                       FontSize="28"
                       Margin="10,0,0,0"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />
            </Grid>
            <ActivityIndicator Grid.Row="1"
                               IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HeightRequest="32"
                               VerticalOptions="Start" />
            <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView x:Name="MainListView"
                      ItemsSource="{Binding Songs}"
                      SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AlbumSong">
                        <Grid ColumnDefinitions="30,*" Padding="10,8" AutomationId="{Binding SongId}">
                            <Label Grid.Column="0"
                                   Text="{Binding TrackNumber}"
                                   TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="0" Margin="10,0,0,0" VerticalOptions="Center">
                                <Label Text="{Binding SongTitle}" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding SongArtists}" FontSize="13" TextColor="{DynamicResource TextSecondary}" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            </RefreshView>
        </Grid>
    </views:BasePage.Content>
</views:BasePage>
