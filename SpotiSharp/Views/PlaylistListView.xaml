<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             x:DataType="viewmodels:PlaylistListViewModel"
             x:Class="SpotiSharp.PlaylistListView">
    <Grid>
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
    <CollectionView x:Name="MainListView"
              ItemsSource="{Binding PlayLists}"
              SelectionMode="Single"
              SelectedItem="{Binding SelectedPlaylist}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Playlist">
                <Grid Margin="0,2,0,0" AutomationId="{Binding PlayListId}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                           x:Name="PlayListImage"
                           Source="{Binding PlayListImageURL}"
                           Aspect="AspectFill"
                           HeightRequest="60"
                           WidthRequest="60" />
                    <Label Grid.Column="1" Grid.Row="0"
                           x:Name="PlayListName"
                           FontSize="18"
                           Margin="10"
                           Text="{Binding PlayListTitle}" />
                    <Label Grid.Column="1" Grid.Row="1"
                           x:Name="SongCount"
                           Margin="15,0,10,0"
                           Text="{Binding SongAmount, StringFormat='{0} Songs'}" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    </RefreshView>

    <!-- Opaque cover shown while the list first populates, so the rows inflate under it
         instead of freezing the flyout as it slides closed. -->
    <Grid IsVisible="{Binding IsLoading}" BackgroundColor="{DynamicResource PageBackground}">
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           HeightRequest="40"
                           WidthRequest="40"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
    </Grid>
</ContentView>