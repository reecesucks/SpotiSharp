<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpotiSharp.Views.RecentEpisodesListView">
    <ListView x:Name="MainListView" ItemsSource="{Binding RecentEpisodes}">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell AutomationId="{Binding EpisodeId}">
                    <Grid Margin="10,2,10,2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                               Source="{Binding ImageUrl}"
                               Aspect="AspectFill"
                               HeightRequest="60"
                               WidthRequest="60" />
                        <Label Grid.Column="1" Grid.Row="0"
                               FontSize="18"
                               Margin="10,0,0,0"
                               Text="{Binding EpisodeName}" />
                        <Label Grid.Column="1" Grid.Row="1"
                               Margin="10,0,0,0"
                               Text="{Binding ShowName}" />
                        <Label Grid.Column="1" Grid.Row="2"
                               Margin="10,0,0,0"
                               Text="{Binding ReleaseDate, StringFormat='{0:d}'}" />
                    </Grid>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentView>
