<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:SpotiSharp.Converters"
             xmlns:controls="clr-namespace:SpotiSharp.Controls"
             x:Class="SpotiSharp.Views.PlayerBarView">
    <ContentView.Resources>
        <converters:BooleanConverter x:Key="InverseBool" />
        <Style x:Key="IconTapTarget" TargetType="controls:PlayerBarButton">
            <Setter Property="WidthRequest" Value="44" />
            <Setter Property="HeightRequest" Value="44" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="Icon" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource Gray300}" />
            <Setter Property="Aspect" Value="Uniform" />
            <Setter Property="WidthRequest" Value="20" />
            <Setter Property="HeightRequest" Value="20" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="InputTransparent" Value="True" />
        </Style>
        <Style x:Key="RotationLabel" TargetType="Label">
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="{DynamicResource Gray300}" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="InputTransparent" Value="True" />
        </Style>
    </ContentView.Resources>

    <Grid Padding="15,5" RowSpacing="2" IsVisible="{Binding HasCurrentSong}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- player controls -->
        <HorizontalStackLayout Grid.Row="0" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">

            <!-- rotation down -->
            <controls:PlayerBarButton Style="{StaticResource IconTapTarget}" Margin="0,0,10,0"
                                      IsVisible="{Binding IsTrackPlaying}"
                                      Command="{Binding RotationDown}">
                <Label Text="R-" Style="{StaticResource RotationLabel}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRotationDownBusy}" Value="True">
                            <Setter Property="TextColor" Value="{DynamicResource Primary}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </controls:PlayerBarButton>

            <!-- shuffle (Data is the Spotify default; the iPod variant is swapped in code-behind) -->
            <controls:PlayerBarButton Style="{StaticResource IconTapTarget}" Command="{Binding ChangeShuffle}">
                <Path x:Name="ShuffleIcon"
                      Style="{StaticResource Icon}"
                      Data="M10.59,9.17L5.41,4L4,5.41l5.17,5.17L10.59,9.17z M14.5,4l2.04,2.04L4,18.59L5.41,20L17.96,7.46L20,9.5V4H14.5z M14.83,13.41l-1.41,1.41l3.13,3.13L14.5,20H20v-5.5l-2.04,2.04L14.83,13.41z">
                    <Path.Triggers>
                        <DataTrigger TargetType="Path" Binding="{Binding IsShuffleOn}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource Primary}" />
                        </DataTrigger>
                    </Path.Triggers>
                </Path>
            </controls:PlayerBarButton>

            <!-- previous (Data is the Spotify default; the iPod variant is swapped in code-behind) -->
            <controls:PlayerBarButton Style="{StaticResource IconTapTarget}" Command="{Binding SongBack}">
                <Path x:Name="PrevIcon"
                      Style="{StaticResource Icon}"
                      Data="M6,6h2v12H6V6z M9.5,12l8.5,6V6L9.5,12z" />
            </controls:PlayerBarButton>

            <!-- play / pause -->
            <controls:PlayerBarButton Command="{Binding TogglePlaying}" VerticalOptions="Center">
                <Border StrokeShape="Ellipse"
                        StrokeThickness="0"
                        BackgroundColor="{DynamicResource Primary}"
                        WidthRequest="48"
                        HeightRequest="48">
                    <Grid>
                        <Path Style="{StaticResource Icon}"
                              Fill="{DynamicResource OnPrimary}"
                              Data="M8,5v14l11-7L8,5z"
                              IsVisible="{Binding IsPlaying, Converter={StaticResource InverseBool}}" />
                        <Path Style="{StaticResource Icon}"
                              Fill="{DynamicResource OnPrimary}"
                              Data="M6,19h4V5H6V19z M14,5v14h4V5H14z"
                              IsVisible="{Binding IsPlaying}" />
                    </Grid>
                </Border>
            </controls:PlayerBarButton>

            <!-- next (Data is the Spotify default; the iPod variant is swapped in code-behind) -->
            <controls:PlayerBarButton Style="{StaticResource IconTapTarget}" Command="{Binding SongSkip}">
                <Path x:Name="NextIcon"
                      Style="{StaticResource Icon}"
                      Data="M6,18l8.5-6L6,6V18z M16,6v12h2V6H16z" />
            </controls:PlayerBarButton>

            <!-- repeat (Data is the Spotify default; the iPod variant is swapped in code-behind) -->
            <controls:PlayerBarButton Style="{StaticResource IconTapTarget}" Command="{Binding ChangeRepeat}">
                <Path x:Name="RepeatIcon"
                      Style="{StaticResource Icon}"
                      Data="M7,7h10v3l4-4l-4-4v3H5v6h2V7z M17,17H7v-3l-4,4l4,4v-3h12v-6h-2V17z">
                    <Path.Triggers>
                        <DataTrigger TargetType="Path" Binding="{Binding IsRepeatOn}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource Primary}" />
                        </DataTrigger>
                    </Path.Triggers>
                </Path>
            </controls:PlayerBarButton>

            <!-- rotation up -->
            <controls:PlayerBarButton Style="{StaticResource IconTapTarget}" Margin="10,0,0,0"
                                      IsVisible="{Binding IsTrackPlaying}"
                                      Command="{Binding RotationUp}">
                <Label Text="R+" Style="{StaticResource RotationLabel}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRotationUpBusy}" Value="True">
                            <Setter Property="TextColor" Value="{DynamicResource Primary}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </controls:PlayerBarButton>

        </HorizontalStackLayout>

        <!-- currently playing -->
        <HorizontalStackLayout Grid.Row="1" Spacing="4" HorizontalOptions="Center">
            <controls:PlayerBarButton WidthRequest="36"
                                      HeightRequest="36"
                                      VerticalOptions="Center"
                                      IsVisible="{Binding IsTrackPlaying}"
                                      Command="{Binding ToggleSongLiked}">
                <Grid>
                    <Path Style="{StaticResource Icon}"
                          WidthRequest="18"
                          HeightRequest="18"
                          Data="M16.5,3c-1.74,0-3.41,0.81-4.5,2.09C10.91,3.81,9.24,3,7.5,3C4.42,3,2,5.42,2,8.5c0,3.78,3.4,6.86,8.55,11.54L12,21.35l1.45-1.32C18.6,15.36,22,12.28,22,8.5C22,5.42,19.58,3,16.5,3z M12.1,18.55l-0.1,0.1l-0.1-0.1C7.14,14.24,4,11.39,4,8.5C4,6.5,5.5,5,7.5,5c1.54,0,3.04,0.99,3.57,2.36h1.87C13.46,5.99,14.96,5,16.5,5c2,0,3.5,1.5,3.5,3.5C20,11.39,16.86,14.24,12.1,18.55z"
                          IsVisible="{Binding IsSongLiked, Converter={StaticResource InverseBool}}" />
                    <Path Style="{StaticResource Icon}"
                          WidthRequest="18"
                          HeightRequest="18"
                          Fill="{DynamicResource Primary}"
                          Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z"
                          IsVisible="{Binding IsSongLiked}" />
                </Grid>
            </controls:PlayerBarButton>
            <Label Text="{Binding SongName}"
                   FontSize="16"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
        </HorizontalStackLayout>
    </Grid>
</ContentView>