<?xml version="1.0" encoding="utf-8"?>

<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SpotiSharp.Views"
             xmlns:selectors="clr-namespace:SpotiSharp.Selectors"
             x:Class="SpotiSharp.Views.PodcastsPage">
    <views:BasePage.Resources>
        <DataTemplate x:Key="GroupedTemplate">
            <views:RecentEpisodesListView />
        </DataTemplate>
        <DataTemplate x:Key="FlatTemplate">
            <views:RecentEpisodesFlatListView />
        </DataTemplate>
        <selectors:PodcastPageTemplateSelector x:Key="PageTemplateSelector"
                                                GroupedTemplate="{StaticResource GroupedTemplate}"
                                                FlatTemplate="{StaticResource FlatTemplate}" />
    </views:BasePage.Resources>
    <views:BasePage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Text="Recent Episodes" Margin="8,6" FontSize="16" />
            <CarouselView Grid.Row="1"
                          ItemsSource="{Binding Pages}"
                          ItemTemplate="{StaticResource PageTemplateSelector}"
                          Position="{Binding CurrentPageIndex, Mode=TwoWay}" />
        </Grid>
    </views:BasePage.Content>
</views:BasePage>
