<?xml version="1.0" encoding="utf-8"?>

<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SpotiSharp.Views"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             xmlns:behaviors="clr-namespace:SpotiSharp.Behaviors"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:DataType="viewmodels:RadioPageViewModel"
             x:Name="RadioPageRoot"
             x:Class="SpotiSharp.Views.RadioPage">
    <views:BasePage.ToolbarItems>
        <ToolbarItem Text="Generate" Order="Primary" Priority="0" Command="{Binding GenerateRadio}" />
        <ToolbarItem Text="Settings" Order="Primary" Priority="1" Command="{Binding OpenSettings}" />
    </views:BasePage.ToolbarItems>
    <views:BasePage.Content>
        <Grid>
            <ActivityIndicator IsRunning="{Binding IsGenerating}"
                               IsVisible="{Binding IsGenerating}"
                               HeightRequest="32"
                               VerticalOptions="Start" />

            <CollectionView x:Name="MainListView"
                            ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:RadioItem">
                        <!-- fixed height so every row is uniform and the list only measures once -->
                        <Grid ColumnDefinitions="Auto,*" Padding="8,6" HeightRequest="64">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsCurrent}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Gray900}" />
                                </DataTrigger>
                            </Grid.Triggers>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnItemTapped" />
                            </Grid.GestureRecognizers>
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior Command="{Binding ItemLongPressed, Source={x:Reference RadioPageRoot}}" />
                            </Grid.Behaviors>
                            <Image Grid.Column="0"
                                   Source="{Binding ImageUrl}"
                                   Aspect="AspectFill"
                                   HeightRequest="52"
                                   WidthRequest="52" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="10,0,0,0" VerticalOptions="Center">
                                <Label Text="{Binding Title}"
                                       FontSize="17"
                                       LineBreakMode="TailTruncation">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Text="{Binding Subtitle}"
                                       FontSize="13"
                                       TextColor="Gray"
                                       LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="3"
                                                       IsVisible="{Binding IsPodcastSegment}"
                                                       BindableLayout.ItemsSource="{Binding SegmentPips}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="sys:Boolean">
                                            <BoxView HeightRequest="4"
                                                     WidthRequest="26"
                                                     CornerRadius="2"
                                                     Color="{StaticResource Gray600}">
                                                <BoxView.Triggers>
                                                    <DataTrigger TargetType="BoxView" Binding="{Binding .}" Value="True">
                                                        <Setter Property="Color" Value="{StaticResource Primary}" />
                                                    </DataTrigger>
                                                </BoxView.Triggers>
                                            </BoxView>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </views:BasePage.Content>
</views:BasePage>
