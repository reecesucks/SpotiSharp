<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SpotiSharp.Models"
             xmlns:viewmodels="clr-namespace:SpotiSharp.ViewModels"
             x:DataType="viewmodels:ArtistListViewModel"
             x:Class="SpotiSharp.Views.ArtistListView">
    <Grid>
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
    <CollectionView x:Name="MainListView"
              ItemsSource="{Binding Artists}"
              SelectionMode="Single"
              SelectedItem="{Binding SelectedArtist}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Artist">
                <Grid Margin="0,2,0,0" ColumnDefinitions="Auto,*" AutomationId="{Binding ArtistId}">
                    <Border Grid.Column="0"
                            StrokeShape="Ellipse"
                            StrokeThickness="0"
                            HeightRequest="60"
                            WidthRequest="60">
                        <Image Source="{Binding ArtistImageUrl}"
                               Aspect="AspectFill"
                               HeightRequest="60"
                               WidthRequest="60" />
                    </Border>
                    <Label Grid.Column="1"
                           FontSize="18"
                           Margin="10,0,0,0"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation"
                           Text="{Binding ArtistName}" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    </RefreshView>

    <!-- Opaque cover shown while the list first populates. The flyout slides closed over an
         empty list (cheap), then the rows inflate under this overlay instead of freezing the
         flyout mid-slide. -->
    <Grid IsVisible="{Binding IsLoading}" BackgroundColor="{DynamicResource PageBackground}">
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           HeightRequest="40"
                           WidthRequest="40"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
    </Grid>
</ContentView>
